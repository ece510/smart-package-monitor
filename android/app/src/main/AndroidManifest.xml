<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        BLUETOOTH_CONNECT: Android 12+ (API 31+) runtime permission required to
        talk to an already-bonded device over RFCOMM. No BLUETOOTH_SCAN: the MVP
        does not discover new devices, it only lists already-paired ones (see
        design doc, point 5).
    -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Declares Bluetooth as required hardware; the app has no purpose without it. -->
    <uses-feature
        android:name="android.hardware.bluetooth"
        android:required="true" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartPackageTripHistory">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
